<Window x:Class="WeerAPI.Presentation.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weer API - JsonDocument Demo" Height="600" Width="800"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Zoekbalk -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="cityTextBox" Width="200" Margin="0,0,10,0" FontSize="14" Padding="5"/>
            <Button Content="Zoek Weer" Click="ZoekButton_Click" Padding="10,5" FontSize="14"/>
        </StackPanel>

        <!-- Weer info -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="cityLabel" Text="Stad: -" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="tempLabel" Text="Temperatuur: -" FontSize="14" Margin="0,5,0,0"/>
                    <TextBlock x:Name="feelsLikeLabel" Text="Voelt als: -" FontSize="14" Margin="0,5,0,0"/>
                    <TextBlock x:Name="descLabel" Text="Beschrijving: -" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="humidityLabel" Text="Luchtvochtigheid: -" FontSize="14"/>
                    <TextBlock x:Name="windLabel" Text="Windsnelheid: -" FontSize="14" Margin="0,5,0,0"/>
                    <Button x:Name="saveButton" Content="Opslaan in Database" Click="SaveButton_Click"
                            Padding="10,5" FontSize="14" Margin="0,15,0,0" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Opgeslagen records -->
        <DataGrid x:Name="recordsGrid" Grid.Row="2" AutoGenerateColumns="False"
                  IsReadOnly="True" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Stad" Binding="{Binding City}" Width="120"/>
                <DataGridTextColumn Header="Temp (°C)" Binding="{Binding Temperature, StringFormat=F1}" Width="90"/>
                <DataGridTextColumn Header="Beschrijving" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Opgeslagen" Binding="{Binding SavedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Delete knop -->
        <Button Grid.Row="3" Content="Verwijder Geselecteerde" Click="DeleteButton_Click" Padding="10,5" FontSize="14" HorizontalAlignment="Right"/>
    </Grid>
</Window>
